# GitHub source of wiki content
GITHUB_REPO=your-gh-user/your-wiki-repo
GITHUB_BRANCH=main

# MCP server display name (used in instructions string)
WIKI_SERVER_NAME=my-wiki

# Snapshot cache TTL seconds
CACHE_TTL_SECONDS=60

# Schema discovery globs (comma-separated)
SCHEMA_GLOBS=CLAUDE.md,*/CLAUDE.md,docs/llm-wiki.md

# Domain detector criteria (comma-separated required files)
DOMAIN_REQUIRED_FILES=index.md,log.md

# Secrets (set via `wrangler secret put`, not this file)
# MCP_BEARER=<32-byte hex, generate: openssl rand -hex 32>
# GITHUB_TOKEN=<fine-grained PAT, contents:read on the wiki repo>
