# wiki-mcp — example environment variables
# ==========================================
#
# Two file conventions in this project:
#
#   wrangler.toml [vars]   public, committed, redeployed via `wrangler deploy`
#   .dev.vars              local-only secrets, gitignored, picked up by `wrangler dev`
#
# Production secrets land via `wrangler secret put NAME` (or `--env dev` for the
# dev environment); they live encrypted in Cloudflare's secret store and never
# appear in this repo. Manual edits in the Cloudflare dashboard are overwritten
# on the next `wrangler deploy` — only durable update path is editing the
# config and redeploying.
#
# Each var below is annotated with: where it lives, default, purpose, and any
# rotation/leak considerations.


# ============================================================================
# Required — non-secret config (wrangler.toml [vars])
# ============================================================================

# GitHub source of wiki content. Format: owner/name. Read by src/github.ts to
# fetch the tree and raw blobs. The one var every fork MUST change.
GITHUB_REPO=your-gh-user/your-wiki-repo

# Branch to read. Defaults to "main"; we use "wiki" for our setup. Doesn't
# need to be the repo's default branch — useful if you maintain a separate
# `staging` or `wiki` branch for content.
GITHUB_BRANCH=main

# Display name shown to Claude in serverInfo.name and embedded in the
# generated `instructions` string. Cosmetic + identity disambiguation:
# differentiates multiple wiki workers in the same Claude session. Don't
# include PII — it appears in every transcript.
WIKI_SERVER_NAME=my-wiki

# How long the in-memory snapshot is "fresh" before triggering a
# stale-while-revalidate refresh. Lower = faster visibility of wiki edits +
# more GitHub API calls. Higher = fewer calls + staler reads. SWR semantics:
# stale snapshot served immediately, refresh fires in background via
# ctx.waitUntil(). Stored as string per Cloudflare binding convention;
# parseInt happens in src/env.ts ttlMs(). Non-numeric falls back to 60s.
CACHE_TTL_SECONDS=60

# Comma-separated globs marking "schema" docs — the meta-instructions for
# your wiki (naming conventions, citation rules, taxonomy). Concatenated and
# shipped in every wiki_context bundle. Glob is simplified: `*` matches one
# path segment, no `**` recursion. See src/discover.ts matchGlob.
SCHEMA_GLOBS=CLAUDE.md,*/CLAUDE.md,docs/llm-wiki.md

# Files that must exist in a top-level folder for that folder to be promoted
# to a "domain". Avoids treating node_modules/, .github/, etc. as domains.
# Files in this list are also auto-served via the wiki://index/all and
# wiki://log/recent resources. Empty list = every top-level folder becomes
# a domain (probably too permissive).
DOMAIN_REQUIRED_FILES=index.md,log.md


# ============================================================================
# Optional — non-secret config (wrangler.toml [vars])
# ============================================================================

# Max bytes accepted by the wiki_upload tool. 25 MB matches GitHub's contents
# API single-blob limit. Larger files would need Git LFS or chunked upload —
# not implemented. Stored as string; parsed via Number() in src/upload.
MAX_UPLOAD_BYTES=26214400

# Subfolder under each domain where wiki_upload writes blobs. Default `raw`
# matches the LLM Wiki Pattern convention (raw/ holds attachments,
# wiki/ holds curated markdown). Override if your repo uses a different name.
RAW_FOLDER=raw

# Privacy gate for the dynamic-priming feature.
#   structural (default) — domain names + type names + counts in instructions
#                          and tool descriptions; titles only in
#                          wiki://overview resources (clients fetch on demand).
#   full                 — ALSO injects up to 50 titles into instructions and
#                          30 into the wiki_context tool description. Max
#                          trigger signal, max leak surface (titles flow into
#                          every transcript).
#   off                  — minimal one-liner instructions, static pre-priming
#                          tool descriptions, suppressed overview bodies.
#                          Use for compliance scenarios.
# Trade-off is signal vs leak; structural is the safe default.
WIKI_PRIME_VOCAB=structural

# Free-form one-line (or short multi-line) string prepended to both the
# `instructions` field and the `wiki://overview` resource. Use for fork
# identity, e.g. "Riva's labor-law wiki, Italian-only". Emitted verbatim —
# no markdown sanitization. Don't put secrets here; it's plain text in
# every transcript.
WIKI_PRIME_GREETING=


# ============================================================================
# Required — secrets (NEVER commit; set via wrangler secret put / .dev.vars)
# ============================================================================

# Bearer token clients send in `Authorization: Bearer <value>` to gate every
# /mcp request. Generate fresh: openssl rand -hex 32. Use a different bearer
# per environment (dev vs prod) so a leak in one doesn't expose the other.
# Static credential — no built-in TTL. Rotation is policy-driven; pair with
# MCP_BEARER_NEXT below for zero-downtime swap.
# MCP_BEARER=<32-byte hex>

# GitHub fine-grained PAT for the wiki repo. Required permissions:
#   Contents: Read         (sufficient for read-only worker)
#   Contents: Read & write  (required if you use the wiki_upload tool)
#   Metadata: Read         (mandatory baseline)
# Fine-grained > classic PAT: scoped to one specific repo, smaller blast
# radius if leaked. Authenticated GitHub API gives 5000 req/hour vs 60 for
# anonymous — the cache TTL design assumes auth.
# GITHUB_TOKEN=<fine-grained PAT>


# ============================================================================
# Optional — secrets
# ============================================================================

# Secondary bearer slot accepted alongside MCP_BEARER. Enables zero-downtime
# rotation: stage new bearer in _NEXT, roll clients over one by one, then
# promote _NEXT to primary and unset _NEXT. Skip if you can atomically swap
# all client configs (single-user setup); useful for shared workers, multiple
# Claude clients, or compromised-credential scenarios.
# MCP_BEARER_NEXT=<32-byte hex>
